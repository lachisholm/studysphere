
<!-- Basic HTML document structure -->
<!DOCTYPE html>
<html lang="en">

<head>
  <!-- Set character encoding -->
  <meta charset="UTF-8">

  <!-- Ensure proper scaling on mobile devices -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Title shown in browser tab -->
  <title>StudySphere</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

  <!-- Navigation Bar -->
  <nav style="background: var(--primary, #4A6FA5); padding: 16px; display: flex; justify-content: flex-end; gap: 16px;">
    <a href="/login" style="color: #fff; text-decoration: none; font-weight: bold;">Login</a>
    <a href="/register" style="color: #fff; text-decoration: none; font-weight: bold;">Register</a>
  </nav>


  <!-- Wrapper for main content to add a hero image section -->
  <div class="hero" style="background: url('/images/studydesk.png') center/cover no-repeat; padding: 80px 0; text-align: center;">
    <h1 style="color: #000;">Welcome to StudySphere</h1>
    <p style="text-align: center; color: #000;">Track your study sessions and improve your learning.</p>
